#!/usr/bin/env bash
# tn — short wrapper around the `therminal` CLI for agent ergonomics.
#
# Goal: reduce token/typing overhead for frequent read flows while keeping
# the full `therminal` binary as the stable contract.
#
# Usage: same as `therminal`, e.g.
#
#   tn pane list              # list panes (terse TSV by default)
#   tn pane peek 3            # tail last 10 lines of pane 3
#   tn agents list            # list detected agents
#   tn workspace list         # list workspace tabs
#   tn events --follow        # stream daemon events as JSON Lines
#   tn semantic commands 1    # recent OSC 633 commands for pane 1
#   tn semantic hotspots 1    # file/URL/git hotspots in pane 1
#
# CLI-vs-MCP policy (encoded here so `tn --help-policy` surfaces it):
#
#   Use CLI (tn) for:
#     - Polling: pane list, pane peek, agents list — called N times per turn
#     - Writes: pane send, pane tag/untag, session/pane create/destroy
#     - Layout: pane focus/move/swap/resize, workspace create/rename/switch
#     - Batch: layout batch (atomic multi-op from stdin)
#     - Hook push: agent-event push (from Claude Code hooks)
#     - Shell dashboards: events --follow piped to jq
#
#   Use MCP for:
#     - Subscriptions: terminal://pane/{id}/output, therminal://claude/events
#     - Blocking waits: terminal.panes.wait_for_output
#     - Conductor tick: terminal.panes.get_summary (MCP-only, ~120 B/call)
#     - Structured shape: get_details, get_cadence, find_with_capacity
#     - Trust-gated destructive ops: MCP sessions.destroy/panes.destroy
#       (MCP enforces trust tier; CLI equivalents skip the gate)
#
# See docs/cli.md for the full decision table.
#
# Installation: copy this script to a directory on $PATH and chmod +x.
# This file is intentionally decoupled from the product name so it can be
# renamed without touching conductor call sites.

set -euo pipefail

if [[ "${1:-}" == "--help-policy" ]]; then
    sed -n '/CLI-vs-MCP policy/,/^# See docs/p' "$0"
    exit 0
fi

# ── Binary discovery ────────────────────────────────────────────────
# 1. THERMINAL_BIN env var (explicit override)
# 2. `therminal` on PATH (native Linux/macOS build, or cargo install)
# 3. `therminal.exe` on PATH (Windows build; WSL interop appends Windows
#    PATH entries by default so this catches most setups)
# 4. Probe Windows Desktop via USERPROFILE (common dev setup: build script
#    copies therminal.exe to Desktop)
#
# To hardwire a path, set THERMINAL_BIN in your shell profile:
#   export THERMINAL_BIN=/mnt/c/Users/you/Desktop/therminal.exe

if [[ -n "${THERMINAL_BIN:-}" ]] && [[ -x "$THERMINAL_BIN" ]]; then
    exec "$THERMINAL_BIN" "$@"
elif command -v therminal &>/dev/null; then
    exec therminal "$@"
elif command -v therminal.exe &>/dev/null; then
    exec therminal.exe "$@"
elif [[ -n "${WSL_DISTRO_NAME:-}" ]]; then
    # WSL2: probe Windows Desktop for a dev build.
    # Try USERPROFILE first (set if WSLENV forwards it), then fall back
    # to cmd.exe to discover the Windows home without hardcoded paths.
    win_home=""
    if [[ -n "${USERPROFILE:-}" ]]; then
        win_home="$(wslpath -u "$USERPROFILE" 2>/dev/null || true)"
    fi
    if [[ -z "$win_home" ]]; then
        win_profile="$(cmd.exe /C "echo %USERPROFILE%" 2>/dev/null | tr -d '\r' || true)"
        [[ -n "$win_profile" ]] && win_home="$(wslpath -u "$win_profile" 2>/dev/null || true)"
    fi
    if [[ -n "$win_home" ]] && [[ -x "$win_home/Desktop/therminal.exe" ]]; then
        exec "$win_home/Desktop/therminal.exe" "$@"
    fi
fi

echo "tn: therminal binary not found" >&2
echo "  Checked: THERMINAL_BIN env, PATH (therminal / therminal.exe), Windows Desktop" >&2
echo "  Fix: set THERMINAL_BIN or add the binary to PATH" >&2
exit 1
